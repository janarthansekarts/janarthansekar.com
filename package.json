{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "prod": "npm run production",
        "production": "mix --production",
        "serve": "npm run dev && vendor/bin/jigsaw serve",
        "build": "npm run prod && vendor/bin/jigsaw build production"
    },
    "devDependencies": {
        "autoprefixer": "^10.4",
        "laravel-mix": "^6.0",
        "postcss": "^8.4",
        "tailwindcss": "^3.4"
    },
    "dependencies": {
        "@tailwindcss/typography": "^0.5.19",
        "laravel-mix-jigsaw": "^2.1.1"
    }
}
